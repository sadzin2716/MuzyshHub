-- ============================================================
--  INICIALIZAÇÃO
-- ============================================================

local function Initialize()
	LogInfo("Iniciando Auto Farm Pro...")
	
	-- Carregar Fluent
	local fluentLoaded = LoadFluent()
	if fluentLoaded then
		BuildUI()
	else
		LogError("Fluent não carregado, UI não disponível")
	end
	
	-- Anti-AFK
	if Services.VirtualUser and LocalPlayer then
		LocalPlayer.Idled:Connect(function()
			Services.VirtualUser:Button2Down(Vector2.new(0,0), Services.Workspace.CurrentCamera.CFrame)
			task.wait(1)
			Services.VirtualUser:Button2Up(Vector2.new(0,0), Services.Workspace.CurrentCamera.CFrame)
		end)
		LogInfo("Anti-AFK ativado")
	end
	
	-- Monitoramento de respawn
	if LocalPlayer then
		LocalPlayer.CharacterAdded:Connect(function(newChar)
			LogInfo("Personagem respawnado")
			Character = newChar
			Humanoid = Character:FindFirstChild("Humanoid")
			HumanoidRootPart = Character:FindFirstChild("HumanoidRootPart")
			
			-- Se estava farmando, continuar
			if Settings.AutoFarm then
				LogInfo("Continuando Auto Farm após respawn")
			end
		end)
	end
	
	LogInfo("Auto Farm Pro inicializado com sucesso")
	
	-- Exibir resumo de logs
	print("=== RESUMO DE LOGS ===")
	print("Infos: " .. #DebugLogs.Infos)
	print("Warnings: " .. #DebugLogs.Warnings)
	print("Errors: " .. #DebugLogs.Errors)
	if #DebugLogs.Errors > 0 then
		print("ERROS ENCONTRADOS:")
		for _, err in ipairs(DebugLogs.Errors) do
			print(" - " .. err)
		end
	end
end

-- Executar inicialização
Initialize()

-- ============================================================
--  LIMPEZA AO SAIR
-- ============================================================

if LocalPlayer then
	LocalPlayer:GetPropertyChangedSignal("Character"):Connect(function()
		if not LocalPlayer.Character then
			StopFarm()
			StopMastery()
			StopBoss()
		end
	end)
end
