-- Sistema de logs
local DebugLogs = {
	Errors = {},
	Warnings = {},
	Infos = {},
}

local function LogInfo(msg)
	table.insert(DebugLogs.Infos, msg)
	print("[INFO] " .. msg)
end

local function LogWarning(msg)
	table.insert(DebugLogs.Warnings, msg)
	warn("[WARN] " .. msg)
end

local function LogError(msg)
	table.insert(DebugLogs.Errors, msg)
	warn("[ERROR] " .. msg)
end

