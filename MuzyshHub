-- ============================================================

local function FarmProcess()
	local quest = CheckAndHandleQuest()
	if not quest then return end

	if HumanoidRootPart then
		local dist = Distance(HumanoidRootPart.Position, quest.MonsterCFrame.Position)
		if dist > 150 then
			TeleportTo(quest.MonsterCFrame)
		end
	end

	local monster = GetClosestMonster(200, {quest.Monster})
	if monster then
		local all = GetAllMonsters(60, {quest.Monster})
		if #all > 3 then
			GroupMonsters()
		end
		AttackMonster(monster)
	else
		TeleportTo(quest.MonsterCFrame * CFrame.new(0, 30, 0))
	end

	local newActive = GetActiveQuestText()
	if newActive and not string.find(newActive, "Defeat") then
		CompleteQuest()
		task.wait(0.5)
	end
end

local function MainFarmLoop()
	if not Settings.AutoFarm then return end
	task.spawn(function()
		pcall(FarmProcess)
	end)
end

local function StartFarm()
	if FarmLoop then FarmLoop:Disconnect() end
	Settings.AutoFarm = true
	FarmLoop = Services.RunService.Heartbeat:Connect(MainFarmLoop)
	LogInfo("Auto Farm iniciado")
end

local function StopFarm()
	Settings.AutoFarm = false
	if FarmLoop then
		FarmLoop:Disconnect()
		FarmLoop = nil
	end
	LogInfo("Auto Farm parado")
end

