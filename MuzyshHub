local function GetQuestForLevel(level, world)
	local best = nil
	if QuestData[world] then
		for _, quest in ipairs(QuestData[world]) do
			if level >= quest.LevelMin and level <= quest.LevelMax then
				if not best or quest.LevelMax > best.LevelMax then
					best = quest
				end
			end
		end
	end
	return best
end

local function GetActiveQuestText()
	local main = Guis.MainGui
	if not main then return nil end
	local questFrame = main:FindFirstChild("Quest")
	if questFrame and questFrame.Visible then
		local container = questFrame:FindFirstChild("Container")
		if container then
			local title = container:FindFirstChild("QuestTitle")
			if title then
				local titleLabel = title:FindFirstChild("Title")
				if titleLabel then
					return titleLabel.Text
				end
			end
		end
	end
	return nil
end

local function AbandonQuest()
	if Remotes.CommF_ then
		SafeInvoke(Remotes.CommF_, "AbandonQuest")
	end
end

local function StartQuest(name, level)
	if Remotes.CommF_ and name and level then
		SafeInvoke(Remotes.CommF_, "StartQuest", name, level)
	end
end

local function CompleteQuest()
	if Remotes.CommF_ then
		SafeInvoke(Remotes.CommF_, "CompleteQuest")
	end
end

local function CheckAndHandleQuest()
	local level = GetLevel()
	local world = GetWorld()
	if world == 0 then return nil end
	local quest = GetQuestForLevel(level, world)
	if not quest then return nil end

	local activeText = GetActiveQuestText()
	local shouldAccept = false

	if not activeText then
		shouldAccept = true
	elseif not string.find(activeText, quest.Monster) then
		AbandonQuest()
		shouldAccept = true
	end

	if shouldAccept and Settings.AcceptQuest then
		TeleportTo(quest.CFrame)
		task.wait(1)
		StartQuest(quest.Name, quest.Level)
		task.wait(1)
	end

	return quest
end

