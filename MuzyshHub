local function GetWorld()
	local placeId = game.PlaceId
	if placeId == 2753915549 or placeId == 85211729168715 then return 1
	elseif placeId == 4442272183 or placeId == 79091703265657 then return 2
	elseif placeId == 7449423635 or placeId == 100117331123089 then return 3
	end
	return 0
end

local function GetLevel()
	local data = LocalPlayer and LocalPlayer:FindFirstChild("Data")
	if data then
		local level = data:FindFirstChild("Level")
		if level then return level.Value end
	end
	return 0
end

local function IsAlive(monster)
	if not monster then return false end
	local humanoid = monster:FindFirstChild("Humanoid")
	return humanoid and humanoid.Health > 0
end

local function GetRootPart(monster)
	if not monster then return nil end
	return monster:FindFirstChild("HumanoidRootPart")
end

local function Distance(pos1, pos2)
	if not pos1 or not pos2 then return math.huge end
	return (pos1 - pos2).Magnitude
end

local function GetCurrentWeapon()
	if not Character then return nil end
	return Character:FindFirstChildOfClass("Tool")
end

local function GetWeaponByType(tooltip)
	if not Backpack then return nil end
	for _, tool in ipairs(Backpack:GetChildren()) do
		if tool:IsA("Tool") and tool.ToolTip == tooltip then
			return tool
		end
	end
	return nil
end

local function EquipWeapon(name)
	if not Backpack or not Humanoid then return false end
	local tool = Backpack:FindFirstChild(name)
	if tool then
		Humanoid:EquipTool(tool)
		return true
	end
	return false
end

local function EquipBestWeapon()
	if not Settings.AutoEquip then return nil end
	local priority = Settings.WeaponPriority
	local types = {
		Melee = "Melee",
		Sword = "Sword",
		Gun = "Gun",
		Fruit = "Blox Fruit"
	}
	local targetType = types[priority]
	if targetType then
		local weapon = GetWeaponByType(targetType)
		if weapon then
			EquipWeapon(weapon.Name)
			return weapon
		end
	end
	-- Fallback
	local first = Backpack and Backpack:GetChildren() or {}
	if #first > 0 then
		EquipWeapon(first[1].Name)
		return first[1]
	end
	return nil
end

local function TeleportTo(cframe)
	if not HumanoidRootPart or not cframe then return end
	local distance = Distance(HumanoidRootPart.Position, cframe.Position)
	if distance > 1000 then
		HumanoidRootPart.CFrame = cframe
	else
		local tweenInfo = TweenInfo.new(distance / Settings.TweenSpeed, Enum.EasingStyle.Linear)
		local tween = Services.TweenService:Create(HumanoidRootPart, tweenInfo, {CFrame = cframe})
		tween:Play()
		while tween.PlaybackState == Enum.PlaybackState.Playing do
			if not Settings.AutoFarm then tween:Cancel() break end
			Services.RunService.RenderStepped:Wait()
		end
	end
end

local function GetClosestMonster(range, names)
	if not WorkspaceObjects.Enemies then return nil end
	local closest = nil
	local closestDist = math.huge
	for _, enemy in ipairs(WorkspaceObjects.Enemies:GetChildren()) do
		if IsAlive(enemy) then
			local root = GetRootPart(enemy)
			if root and HumanoidRootPart then
				local name = enemy.Name
				if not names or table.find(names, name) then
					local dist = Distance(HumanoidRootPart.Position, root.Position)
					if dist < range and dist < closestDist then
						closestDist = dist
						closest = enemy
					end
				end
			end
		end
	end
	return closest
end

local function GetAllMonsters(range, names)
	if not WorkspaceObjects.Enemies then return {} end
	local list = {}
	for _, enemy in ipairs(WorkspaceObjects.Enemies:GetChildren()) do
		if IsAlive(enemy) then
			local root = GetRootPart(enemy)
			if root and HumanoidRootPart then
				local name = enemy.Name
				if not names or table.find(names, name) then
					local dist = Distance(HumanoidRootPart.Position, root.Position)
					if dist < range then
						table.insert(list, enemy)
					end
				end
			end
		end
	end
	return list
end

local function BringMonster(monster)
	if not Settings.BringMobs then return end
	local root = GetRootPart(monster)
	if root and HumanoidRootPart then
		root.CFrame = HumanoidRootPart.CFrame * CFrame.new(0, 0, -5)
		root.Velocity = Vector3.new(0,0,0)
		root.CanCollide = false
		local humanoid = monster:FindFirstChild("Humanoid")
		if humanoid then
			humanoid.WalkSpeed = 0
			humanoid.JumpPower = 0
		end
	end
end

local function UseSkill(key)
	if not Services.VirtualInputManager then return end
	Services.VirtualInputManager:SendKeyEvent(true, key, false, game)
	task.wait(Settings.SkillDelay)
	Services.VirtualInputManager:SendKeyEvent(false, key, false, game)
end

local function AttackMonster(monster)
	if not Settings.AutoFarm then return end
	local root = GetRootPart(monster)
	if not root or not HumanoidRootPart then return end
	local dist = Distance(HumanoidRootPart.Position, root.Position)
	if dist > Settings.FarmDistance then
		TeleportTo(root.CFrame * CFrame.new(0, 10, 0))
	end
	BringMonster(monster)
	EquipBestWeapon()
	if Settings.AutoSkills then
		local keys = {"Z","X","C","V","F"}
		for _, key in ipairs(keys) do
			UseSkill(key)
		end
	end
	if Settings.FastAttack then
		task.spawn(function()
			if Services.VirtualInputManager then
				Services.VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
				task.wait(0.05)
				Services.VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
			end
		end)
	end
end

local function GroupMonsters()
	if not Settings.GroupMobs then return end
	local monsters = GetAllMonsters(50)
	if #monsters > 1 and HumanoidRootPart then
		local center = HumanoidRootPart.Position
		for i, monster in ipairs(monsters) do
			if i > 10 then break end
			local root = GetRootPart(monster)
			if root then
				local offset = Vector3.new(math.random(-4,4), 0, math.random(-4,4))
				root.CFrame = CFrame.new(center + offset)
			end
		end
	end
end

